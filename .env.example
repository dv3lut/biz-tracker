# Sirene API configuration
SIRENE__API_TOKEN=replace-with-token
SIRENE__API_BASE_URL=https://api.insee.fr/api-sirene/3.11
SIRENE__MAX_CALLS_PER_MINUTE=30
SIRENE__PAGE_SIZE=1000
SIRENE__RESTAURANT_NAF_CODES=["56.10A"]
SIRENE__CURRENT_PERIOD_DATE=2100-01-01

# Database configuration
DATABASE__HOST=localhost
DATABASE__PORT=15432
DATABASE__NAME=biz_tracker_db
DATABASE__USER=sirene_user
DATABASE__PASSWORD=sirene_password
DATABASE__ECHO=false
DATABASE__POOL_SIZE=5
DATABASE__POOL_TIMEOUT=30

# Email alerts configuration
EMAIL__ENABLED=false
EMAIL__SMTP_HOST=
EMAIL__SMTP_PORT=587
EMAIL__SMTP_USERNAME=
EMAIL__SMTP_PASSWORD=
EMAIL__USE_TLS=true
EMAIL__FROM_ADDRESS=alerts@example.com
EMAIL__RECIPIENTS=recipient1@example.com,recipient2@example.com

# Logging configuration
LOGGING__LEVEL=INFO
LOGGING__DIRECTORY=logs
LOGGING__ALERTS_LOG_FILENAME=alerts.log
LOGGING__APP_LOG_FILENAME=app.log

# Synchronization configuration
SYNC__SCOPE_KEY=restaurants
SYNC__MINIMUM_DELAY_MINUTES=1440
SYNC__MONTHS_BACK=6
SYNC__AUTO_ENABLED=true
SYNC__AUTO_POLL_MINUTES=15

# API configuration
API__HOST=0.0.0.0
API__PORT=8080
API__ADMIN_TOKEN=replace-with-strong-admin-token
API__ADMIN_HEADER_NAME=X-Admin-Token
API__DOCS_ENABLED=false
API__ALLOWED_ORIGINS=["http://localhost:5173"]
API_IMAGE=docker.io/dv3lut/biz-tracker-back-api:latest
ENABLE_DEBUGPY=0
DEBUGPY_PORT=5678
