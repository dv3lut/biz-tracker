# Runtime environment
APP_ENVIRONMENT=local

# Sirene API configuration
SIRENE__API_TOKEN=replace-with-token
SIRENE__API_BASE_URL=https://api.insee.fr/api-sirene/3.11
SIRENE__MAX_CALLS_PER_MINUTE=30
SIRENE__PAGE_SIZE=1000

# Database configuration
# Local (API lancée depuis l'hôte) : localhost + port mappé (15432)
# Docker Compose (API en container) : utiliser le nom du service Postgres (ex: biztracker-postgres) + port 5432
DATABASE__HOST=localhost
DATABASE__PORT=15432
DATABASE__NAME=biz_tracker_db
DATABASE__USER=sirene_user
DATABASE__PASSWORD=sirene_password
DATABASE__ECHO=false
DATABASE__POOL_SIZE=5
DATABASE__POOL_TIMEOUT=30

# Email alerts configuration
EMAIL__PROVIDER=mailhog
EMAIL__ENABLED=true
EMAIL__SMTP_HOST=null
EMAIL__SMTP_PORT=587
EMAIL__SMTP_USERNAME=null
EMAIL__SMTP_PASSWORD=null@
EMAIL__USE_TLS=true
EMAIL__FROM_ADDRESS=notification@business-tracker.fr

# Google Places enrichment
GOOGLE__API_KEY=
GOOGLE__FIND_PLACE_URL=https://maps.googleapis.com/maps/api/place/findplacefromtext/json
GOOGLE__PLACE_DETAILS_URL=https://maps.googleapis.com/maps/api/place/details/json
GOOGLE__MAX_CALLS_PER_MINUTE=20
GOOGLE__LANGUAGE=fr
GOOGLE__RECHECK_HOURS=24
GOOGLE__DAILY_RETRY_LIMIT=200

# Logging configuration
LOGGING__LEVEL=INFO
LOGGING__DIRECTORY=logs
LOGGING__ALERTS_LOG_FILENAME=alerts.log
LOGGING__APP_LOG_FILENAME=app.log
LOGGING__SERVICE_NAME=biz-tracker-back
LOGGING__ELASTICSEARCH__ENABLED=false
LOGGING__ELASTICSEARCH__HOSTS=["http://localhost:9200"]
LOGGING__ELASTICSEARCH__INDEX_PREFIX=biz-tracker-observability
LOGGING__ELASTICSEARCH__ENVIRONMENT=local
LOGGING__ELASTICSEARCH__VERIFY_CERTS=false
LOGGING__ELASTICSEARCH__TIMEOUT_SECONDS=10

# Synchronization configuration
SYNC__SCOPE_KEY=default
SYNC__MINIMUM_DELAY_MINUTES=1440
SYNC__AUTO_ENABLED=true
SYNC__AUTO_POLL_MINUTES=15

# API configuration
API__HOST=0.0.0.0
API__PORT=8080
API__ADMIN_TOKEN=replace-with-strong-admin-token
API__ADMIN_HEADER_NAME=X-Admin-Token
API__DOCS_ENABLED=false
API__LOG_ADMIN_REQUESTS=false
API__ALLOWED_ORIGINS=["http://localhost:5173"]
API_IMAGE=docker.io/dv3lut/biz-tracker-back-api:latest

# Stripe billing
STRIPE__SECRET_KEY=
STRIPE__WEBHOOK_SECRET=
STRIPE__SUCCESS_URL=https://business-tracker.fr/#pricing
STRIPE__CANCEL_URL=https://business-tracker.fr/#pricing
STRIPE__PORTAL_RETURN_URL=https://business-tracker.fr/upgrade
STRIPE__UPGRADE_URL=https://business-tracker.fr/upgrade
STRIPE__PRICE_IDS={"starter":"price_replace_me","business":"price_replace_me"}

ENABLE_DEBUGPY=0
DEBUGPY_PORT=5678

# ------------------------------
# Variables "infrastructure" (Docker Compose serveur)
#
# Ces variables ne sont PAS consommées par `app/config.py` (pas de `__`).
# Elles servent à paramétrer le `docker-compose` de production (reverse-proxy, Kibana, Elasticsearch).
# Voir `docs/kibana/docker-compose.server.yml`.

# IMPORTANT
# - Les variables qui commencent par `LOGGING__...` (ci-dessus) sont la configuration du BACKEND.
# - Les variables ci-dessous servent uniquement à docker-compose (provisioning Elastic/Kibana, reverse-proxy, etc.).
# - Le provisioning Elastic (rôles/permissions) réutilise `LOGGING__ELASTICSEARCH__INDEX_PREFIX` pour cibler les bons indices.

# Reverse-proxy (jwilder/nginx-proxy + letsencrypt-companion)
LETSENCRYPT_EMAIL=replace-with-ops-email
API_VIRTUAL_HOST=api.business-tracker.fr
KIBANA_VIRTUAL_HOST=kibana.business-tracker.fr
KIBANA_PUBLIC_BASE_URL=https://kibana.business-tracker.fr

# Elastic Stack security (production)
ELASTIC_PASSWORD=replace-with-strong-elastic-password
KIBANA_SYSTEM_PASSWORD=replace-with-strong-kibana-system-password

# TLS transport (truststore PKCS12)
# Keytool impose un mot de passe (>= 6 caractères). Elasticsearch doit connaître ce mot de passe.
ELASTIC_TRANSPORT_SSL_TRUSTSTORE_PASSWORD=changeit

# Note (Docker Compose): si un secret contient des caractères '$', il faut les échapper en '$$'
# (ex: ELASTIC_PASSWORD=a$$bc$$def) pour éviter les substitutions Docker Compose.

# Comptes applicatifs Elastic (production)
# - ELASTIC_LOGGER_* : utilisé par le backend pour indexer les logs (au lieu de `elastic`)
# - KIBANA_UI_* : utilisé pour te connecter à l'UI Kibana (au lieu de `elastic`)
ELASTIC_LOGGER_USERNAME=biztracker_logger
ELASTIC_LOGGER_PASSWORD=replace-with-strong-logger-password
KIBANA_UI_USERNAME=biztracker_admin
KIBANA_UI_PASSWORD=replace-with-strong-kibana-ui-password

# Clés Kibana (doivent être longues et STABLES)
KIBANA_SECURITY_ENCRYPTION_KEY=replace-with-32+-chars
KIBANA_ENCRYPTED_SAVED_OBJECTS_KEY=replace-with-32+-chars
KIBANA_REPORTING_ENCRYPTION_KEY=replace-with-32+-chars
