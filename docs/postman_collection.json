{
  "info": {
    "name": "Biz Tracker Admin API",
    "description": "Collection Postman pour piloter et monitorer l'API d'administration Biz Tracker.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "adminToken",
      "value": "replace-with-admin-token"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "description": "Endpoints réservés aux administrateurs via jeton `X-Admin-Token`.",
      "item": [
        {
          "name": "GET Stats Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Admin-Token",
                "value": "{{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/stats/summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "stats",
                "summary"
              ]
            }
          }
        },
        {
          "name": "GET Sync Runs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Admin-Token",
                "value": "{{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/sync-runs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "sync-runs"
              ]
            }
          }
        },
        {
          "name": "GET Sync State",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Admin-Token",
                "value": "{{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/sync-state",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "sync-state"
              ]
            }
          }
        },
        {
          "name": "GET Recent Alerts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Admin-Token",
                "value": "{{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/alerts/recent",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "alerts",
                "recent"
              ]
            }
          }
        },
        {
          "name": "POST Sync Full",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Admin-Token",
                "value": "{{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resume\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/sync/full",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "sync",
                "full"
              ]
            }
          }
        },
        {
          "name": "POST Sync Incremental",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Admin-Token",
                "value": "{{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/sync/incremental",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "sync",
                "incremental"
              ]
            }
          }
        }
      ]
    }
  ]
}
